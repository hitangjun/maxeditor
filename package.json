{
  "name": "maxeditor",
  "displayName": "Max Editor",
  "description": "Maximize/Restore editor layout - 最大化/恢复编辑器布局",
  "version": "1.0.0",
  "publisher": "hitangjun",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "maximize",
    "editor",
    "sidebar",
    "fullscreen",
    "vscode",
    "toggle"
  ],
  "galleryBanner": {
    "color": "#1e1e3f",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "maxeditor.toggleMaximize",
        "title": "Max Editor: 最大化/恢复编辑器",
        "icon": "$(screen-full)"
      }
    ],
    "keybindings": [
      {
        "command": "maxeditor.toggleMaximize",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "maxeditor.toggleMaximize",
          "group": "navigation",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "package": "vsce package --no-dependencies"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hitangjun/maxeditor"
  },
  "license": "MIT"
}
